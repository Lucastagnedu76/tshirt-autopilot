# ─── ANTHROPIC ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Modèle Claude à utiliser (défaut : haiku = rapide + pas cher)
# Options : claude-haiku-4-5-20251001 | claude-sonnet-5 | claude-opus-4-8
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ─── SHOPIFY ─────────────────────────────────────────────────────────────────
SHOPIFY_SHOP=ma-boutique.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...
SHOPIFY_WEBHOOK_SECRET=...     # Dans Shopify Admin > Paramètres > Notifications > Webhooks

# ─── MARQUE ──────────────────────────────────────────────────────────────────
BRAND_NAME=Ma Boutique
BRAND_VOICE=moderne, streetwear, authentique, sans bullshit

# ─── SERVEUR ─────────────────────────────────────────────────────────────────
PORT=3000
